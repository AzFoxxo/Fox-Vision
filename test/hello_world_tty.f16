:main
; Hello, World! over VF16TTY on PORT4 (UI port 5).
; Requires extended mode and the fixed TTY port.

MOV %1 EM

MOV %72 X
OUT X PORT4
MOV %101 X
OUT X PORT4
MOV %108 X
OUT X PORT4
MOV %108 X
OUT X PORT4
MOV %111 X
OUT X PORT4
MOV %44 X
OUT X PORT4
MOV %32 X
OUT X PORT4
MOV %87 X
OUT X PORT4
MOV %111 X
OUT X PORT4
MOV %114 X
OUT X PORT4
MOV %108 X
OUT X PORT4
MOV %100 X
OUT X PORT4
MOV %33 X
OUT X PORT4
MOV %10 X
OUT X PORT4
HLT
