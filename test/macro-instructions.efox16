@efox16_required

; Breakdown

; Register to X

; Register to register
MOV #A #B


; Register to memory
    MOV #A $FFFF


; Memory to X

; Memory to register
 MOV $FFFF #A

; Memory to memory
MOV $FFFF $FFFF



; Immediate to X

; Immediate to register
MOV !%1 #A
MOV !$FFFF #B

; Immediate to memory
MOV !%1 $FFFF
MOV !$FFFF $FFFF


; EFox16 test
@const A %0
@const B %1
@const C $FFFF
MOV #<A> #<B>
MOV #<A> #<C>
MOV <C> #<A>