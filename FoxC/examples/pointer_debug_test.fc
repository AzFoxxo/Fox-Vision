// Debug pointer operations step by step
void main()
{
    u16 result = 0;

    // Test 1: u16 pointer dereference
    u16 v = 4660;
    u16 *pv = &v;
    if (*pv == 4660)
    {
        result = 1;  // Test 1 passed
    }
    else
    {
        out_port(4, 49); // '1' - test 1 failed
    }

    // Test 2: u8 array initialization and pointer
    u8 bytes[3];
    bytes[0] = 1;
    bytes[1] = 2;
    bytes[2] = 3;
    u8 *bp = &bytes[0];

    if (*(bp) == 1)
    {
        result = 2;  // Test 2 passed
    }
    else
    {
        out_port(4, 50); // '2' - test 2 failed
    }

    if (*(bp + 1) == 2)
    {
        result = 3;  // Test 3 passed
    }
    else
    {
        out_port(4, 51); // '3' - test 3 failed
    }

    if (*(bp + 2) == 3)
    {
        result = 4;  // Test 4 passed
    }
    else
    {
        out_port(4, 52); // '4' - test 4 failed
    }

    // Test 5: dereference assignment
    *(bp + 1) = 5;
    if (bytes[1] == 5)
    {
        result = 5;  // Test 5 passed
    }
    else
    {
        out_port(4, 53); // '5' - test 5 failed
    }

    // If all tests passed
    if (result == 5)
    {
        out_port(4, 80); // 'P'
        out_port(4, 65); // 'A'
        out_port(4, 83); // 'S'
        out_port(4, 83); // 'S'
    }
}
